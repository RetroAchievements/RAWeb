# ------------------------------------------------------------------
# Docker ports
# Containers claim the 640xx port range to avoid host collisions.
# ------------------------------------------------------------------

APP_PORT=64000
PHP_PORT=64007
OCTANE_PORT=64008
VITE_PORT=64009
FORWARD_DB_PORT=64010
FORWARD_REDIS_PORT=64030
FORWARD_MINIO_PORT=64040
FORWARD_MINIO_CONSOLE_PORT=64041
FORWARD_MAILPIT_DASHBOARD_PORT=64050
FORWARD_MAILPIT_PORT=64051
FORWARD_MEILISEARCH_PORT=64060

# ------------------------------------------------------------------
# Application
# ------------------------------------------------------------------

APP_NAME=RetroAchievements
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_VERSION=DEV
#APP_BRANCH=master

APP_URL=http://localhost:${APP_PORT}
# Uncomment and adjust when serving through a custom domain (eg: Valet).
#APP_URL=https://raweb.test
#ASSET_URL=http://localhost:${APP_PORT}
#MEDIA_URL=http://localhost:${APP_PORT}/media
#MEDIA_URL=http://localhost:${FORWARD_MINIO_PORT}/local
#API_URL=http://localhost:${APP_PORT}/api
#CONNECT_URL=http://localhost:${APP_PORT}/api/connect

# ------------------------------------------------------------------
# Database
# ------------------------------------------------------------------

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
# Use the forwarded port when connecting from the host to the Docker database.
#DB_PORT=${FORWARD_DB_PORT}
DB_DATABASE=retroachievements
DB_USERNAME=retroachievements
DB_PASSWORD="${DB_USERNAME}"

# ------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Use the forwarded port when connecting from the host to the Docker instance.
#REDIS_PORT=${FORWARD_REDIS_PORT}
REDIS_CLIENT=predis
#REDIS_DB=0
#REDIS_CACHE_DB=1
#REDIS_QUEUE_DB=2

# ------------------------------------------------------------------
# Cache, queue, session, filesystem
# ------------------------------------------------------------------

#CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=10080
SESSION_SECURE_COOKIE=false
FILESYSTEM_DISK=local
HASH_DRIVER=bcrypt
RESPONSE_CACHE_ENABLED=false
#HORIZON_LOCAL_USE_FULL_SUPERVISORS=true

# ------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ------------------------------------------------------------------
# Servers
# Octane serves the app. Inertia SSR renders React pages server-side.
# ------------------------------------------------------------------

OCTANE_SERVER=frankenphp
OCTANE_HTTPS=false

#VITE_INERTIA_SSR_PORT=13714
#INERTIA_SSR_CLUSTER=false
#INERTIA_SSR_CONNECT_TIMEOUT=1
#INERTIA_SSR_TIMEOUT=2

# ------------------------------------------------------------------
# Frontend build
# ------------------------------------------------------------------

VITE_BUILD_PATH=assets/build/${APP_VERSION}
VITE_USE_DEV_SSL=false
VITE_BASE_URL=localhost

# ------------------------------------------------------------------
# Auth (Passport)
# Keys are generated by "composer setup".
# ------------------------------------------------------------------

PASSPORT_PERSONAL_ACCESS_CLIENT_ID=
PASSPORT_PERSONAL_ACCESS_CLIENT_SECRET=
PASSPORT_PRIVATE_KEY=
PASSPORT_PUBLIC_KEY=

# ------------------------------------------------------------------
# Mail
# The log mailer writes mail to the Laravel log. Switch to smtp to
# inspect mail in Mailpit instead.
# ------------------------------------------------------------------

MAIL_MAILER=log
#MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=${FORWARD_MAILPIT_PORT}
MAIL_USERNAME="${DB_USERNAME}"
MAIL_PASSWORD="${DB_USERNAME}"
MAIL_FROM_ADDRESS=noreply@retroachievements.org
MAIL_FROM_NAME="${APP_NAME}"

# ------------------------------------------------------------------
# Search (Scout / Meilisearch)
# ------------------------------------------------------------------

SCOUT_DRIVER=meilisearch
SCOUT_PREFIX=
SCOUT_QUEUE=true
MEILISEARCH_NO_ANALYTICS=true
MEILISEARCH_HOST=http://meilisearch:7700
# Local-only dummy key matching the Docker service. Not a production secret.
MEILISEARCH_KEY=c0f9L4BrnVg9CoWXzy70olfWgrsct888

# ------------------------------------------------------------------
# File storage (S3 / MinIO)
# Local-only dummy credentials matching the Docker MinIO service.
# ------------------------------------------------------------------

AWS_ACCESS_KEY_ID="${DB_USERNAME}"
AWS_SECRET_ACCESS_KEY="${DB_USERNAME}"
AWS_BUCKET=local
AWS_DEFAULT_REGION=eu-west-1
AWS_USE_PATH_STYLE_ENDPOINT=false
#AWS_MINIO=true
#AWS_URL=http://localhost:${FORWARD_MINIO_PORT}/local

# ------------------------------------------------------------------
# Media processing
# ------------------------------------------------------------------

#IMAGE_DRIVER=imagick
#FFMPEG_PATH=/usr/bin/ffmpeg
#FFPROBE_PATH=/usr/bin/ffprobe

CLAMAV_SKIP_VALIDATION=true
CLAMAV_UNIX_SOCKET=

# ------------------------------------------------------------------
# Feature flags
# ------------------------------------------------------------------

FEATURE_GAME_SCREENSHOT_UPLOADS=true
SCREENSHOT_MAX_PENDING_SUBMISSIONS_PER_USER=200

FEATURE_OAUTH=true
OAUTH_MAX_APPLICATIONS_PER_USER=5

# ------------------------------------------------------------------
# Connect API rate limits
# Applies to emulator integration traffic on dorequest.php.
# ------------------------------------------------------------------

#CONNECT_RATE_LIMIT_PUBLISH_PER_MINUTE=600
#CONNECT_RATE_LIMIT_DEFAULT_PER_MINUTE=180
#CONNECT_RATE_LIMIT_DELEGATED_PER_MINUTE=6000
#CONNECT_RATE_LIMIT_LOGIN_PER_IP=300
#CONNECT_RATE_LIMIT_LOGIN_PER_USER_IP=30

# ------------------------------------------------------------------
# ID obfuscation (Optimus)
# ------------------------------------------------------------------

OPTIMUS_PRIME=1580030173
OPTIMUS_INVERSE=59260789
OPTIMUS_RANDOM=246216635
# OPTIMUS_BIT_LENGTH=4-62
OPTIMUS_BIT_LENGTH=31

# ------------------------------------------------------------------
# Debugging and monitoring
# ------------------------------------------------------------------

DEBUGBAR_ENABLED=true
#VITE_REACT_QUERY_DEVTOOLS_ENABLED=false
#IGNITION_THEME=dark
CSP_ENABLED=false

SENTRY_LARAVEL_DSN=
VITE_SENTRY_DSN="${SENTRY_LARAVEL_DSN}"
SENTRY_AUTH_TOKEN=
SENTRY_TRACES_SAMPLE_RATE=
SENTRY_REPLAYS_SESSION_SAMPLE_RATE=

# ------------------------------------------------------------------
# External services
# All optional for local development.
# ------------------------------------------------------------------

BLUESKY_CHANNEL=

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

DISCORD_INVITE_ID=
# RABot
DISCORD_GUILD_ID=
DISCORD_RABOT_TOKEN=
# public feeds
DISCORD_WEBHOOK_ACHIEVEMENTS=
DISCORD_WEBHOOK_NAME_CHANGES=
DISCORD_WEBHOOK_NEWS=
DISCORD_WEBHOOK_USERS=
# moderation feeds
DISCORD_WEBHOOK_MOD_FORUMS=
DISCORD_WEBHOOK_MOD_SENTRY=
# inboxes
DISCORD_WEBHOOK_CODEREVIEWERS=
DISCORD_WEBHOOK_DEVCOMPLIANCE=
DISCORD_WEBHOOK_DEVCOMPLIANCE_UNWELCOME_CONCEPT=
DISCORD_WEBHOOK_DEVQUEST=
DISCORD_WEBHOOK_MOD=
DISCORD_WEBHOOK_MOD_VERIFY=
DISCORD_WEBHOOK_MOD_REPORTS=
DISCORD_WEBHOOK_QATEAM=
DISCORD_WEBHOOK_QATEAM_ACHIEVEMENT_ISSUES=
DISCORD_WEBHOOK_QATEAM_INCORRECT_TYPE=
DISCORD_WEBHOOK_QUALITYQUEST=
DISCORD_WEBHOOK_RACHEATS=
DISCORD_WEBHOOK_RAEVENTS=
DISCORD_WEBHOOK_RANEWS=
DISCORD_WEBHOOK_SETDESIGN_TEAM=
DISCORD_WEBHOOK_UNLOCKTEAM=
DISCORD_WEBHOOK_WRITING_TEAM=
# alerts
DISCORD_WEBHOOK_ALERT_CLAIM_WITH_UNRESOLVED_TICKETS=
DISCORD_WEBHOOK_ALERT_DEVELOPER_INACTIVITY=
DISCORD_WEBHOOK_ALERT_INAPPROPRIATE_GAME_SCREENSHOT=
DISCORD_WEBHOOK_ALERT_MUTED_USER_MESSAGE=
DISCORD_WEBHOOK_ALERT_SET_CLAIM_CHANGE=
DISCORD_WEBHOOK_ALERT_SUSPICIOUS_BEAT_TIME=
DISCORD_WEBHOOK_ALERT_SUSPICIOUS_CONNECT_WARNING=
# roles
DISCORD_ROLE_ADMIN=
DISCORD_ROLE_DEVCOMPLIANCE=
DISCORD_ROLE_EVENTS=
DISCORD_ROLE_INVESTIGATOR=
DISCORD_ROLE_MODERATOR=
DISCORD_ROLE_MUTED=
DISCORD_ROLE_QATEAM=

FACEBOOK_CLIENT_ID=

GITHUB_ORG=RetroAchievements

GOOGLE_RECAPTCHA_KEY=
GOOGLE_RECAPTCHA_SECRET=

PATREON_USER_ID=5403777

REDDIT_CHANNEL=RetroAchievements

TWITTER_CHANNEL=retrocheevos

# ------------------------------------------------------------------
# Internal API
# Service accounts allowed to access internal API endpoints, as a
# comma-separated list of user IDs (eg: RABot's user ID).
# ------------------------------------------------------------------

INTERNAL_API_ALLOWED_USER_IDS=
